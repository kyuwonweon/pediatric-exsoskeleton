# ==========================================
# VS Code
# ==========================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# ==========================================
# Python
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (for your host machine tools)
venv/
env/
.venv/
.env
pip-log.txt
pip-delete-this-directory.txt

# Testing, Coverage, and Type Checking
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/

# Jupyter Notebooks (if used for testing/prototyping)
.ipynb_checkpoints/

# ==========================================
# MicroPython
# ==========================================
# Pre-compiled MicroPython byte-code
*.mpy

# Firmware binaries and build directories (if compiling custom firmware)
build/
build-*/
*.bin
*.uf2
*.hex
*.elf
*.map

# MicroPython tools cache/config (e.g., mpremote, mip)
.micropython/

# ==========================================
# OS Generated Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db